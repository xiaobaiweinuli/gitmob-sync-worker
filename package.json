{
  "name": "gitmob-sync-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":    "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute gitmob-sync-db --file=schema.sql",
    "db:init:preview": "wrangler d1 execute gitmob-sync-db --local --file=schema.sql",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.80.0"
  }
}
